
# OS
.DS_Store
Thumbs.db

# Logs (but committed test fixtures are allowed)
*.log
!packages/**/test/fixtures/**/*.log
!apps/**/test/fixtures/**/*.log

# Node / TypeScript (tarkov-ai-companion)
node_modules/
*.tsbuildinfo
.env
.env.*
# wiki fetch cache (re-fetchable; fixtures live in test/fixtures)
data/cache/
# per-profile SQLite state, config, tokens (local mutable data — never committed)
data/local/

# build artifacts
apps/web/dist/

# Local read-only reference checkouts of upstream projects (GPL-3.0). Studied,
# never vendored — our code is reimplemented in our own idiom + attributed.
/TarkovMonitor/
/TarkovTracker/

# Stray local profile dirs (canonical is /data/local, already ignored)
**/data/local/
